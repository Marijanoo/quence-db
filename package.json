{
  "name": "quence-db",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node server.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"wait-on tcp:3001 && npm run build:electron && electron . 3001\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "build:electron-win": "npm run build && npm run build:electron && electron-builder --win --publish never",
    "build:electron-mac": "npm run rebuild && npm run build && npm run build:electron && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.quence.db",
    "productName": "QuenceDB",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Marijanoo",
      "repo": "quence-db"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "package.json",
      "public/logo.png",
      "public/logo.ico",
      "public/logo.icns",
      "node_modules/better-sqlite3/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "icon": "public/logo.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/logo.ico",
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": true
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "electron-serve": "^1.1.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.564.0",
    "mongodb": "^7.2.0",
    "mysql2": "^3.22.3",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19",
    "react-dom": "^19",
    "react-resizable-panels": "^2.1.7",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "ws": "^8.20.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mongodb": "^4.0.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.7.3",
    "wait-on": "^9.0.10"
  }
}

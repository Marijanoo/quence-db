{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["dom", "es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist-electron",
    "resolveJsonModule": true
  },
  "include": ["**/*.ts"]
}
